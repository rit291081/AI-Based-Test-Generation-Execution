from __future__ import annotations

import json
import os
from typing import Any, Dict, List

from ..models.test_case import TestCase


class LLMClient:
    def __init__(self, model: str | None = None) -> None:
        self.model = model or os.getenv("OPENAI_MODEL", "gpt-4.1-mini")
        self.api_key = os.getenv("OPENAI_API_KEY")

    def is_available(self) -> bool:
        return bool(self.api_key)

    def generate(self, prompt: str, spec: Dict[str, Any]) -> List[Dict[str, Any]]:
        if not self.is_available():
            return self._offline_generate(spec)

        try:
            from openai import OpenAI  # type: ignore
        except Exception:
            return self._offline_generate(spec)

        client = OpenAI(api_key=self.api_key)
        response = client.chat.completions.create(
            model=self.model,
            messages=[
                {"role": "system", "content": "You generate QA test cases as valid JSON only."},
                {"role": "user", "content": prompt},
            ],
            temperature=0.2,
        )
        content = response.choices[0].message.content or "[]"
        try:
            parsed = json.loads(content)
            if isinstance(parsed, list):
                return parsed
        except Exception:
            pass
        return self._offline_generate(spec)

    def _offline_generate(self, spec: Dict[str, Any]) -> List[Dict[str, Any]]:
        title = spec.get("title", "API")
        endpoint = spec.get("endpoint", "/unknown")
        method = spec.get("method", "N/A")
        request = spec.get("request", {})
        constraints = spec.get("constraints", [])

        cases = [
            TestCase(
                id="TC-001",
                title=f"{title} - valid {method} request succeeds",
                type="positive",
                priority="high",
                preconditions=["User is authenticated"],
                steps=[
                    f"Send a valid {method} request to {endpoint}",
                    "Include all required request fields",
                    "Verify response status and payload",
                ],
                expected_result="Request succeeds and returns the expected response payload.",
                data={"request": request},
                tags=["smoke", "api", "positive"],
            ),
            TestCase(
                id="TC-002",
                title=f"{title} - missing required field returns validation error",
                type="negative",
                priority="high",
                preconditions=["User is authenticated"],
                steps=[
                    f"Send a {method} request to {endpoint} with a required field removed",
                    "Verify validation response",
                ],
                expected_result="API returns a validation error for missing required fields.",
                data={"missing_field": "required"},
                tags=["negative", "validation", "api"],
            ),
            TestCase(
                id="TC-003",
                title=f"{title} - boundary condition around constraints",
                type="edge",
                priority="medium",
                preconditions=["User is authenticated"],
                steps=[
                    f"Submit edge-case values for {endpoint}",
                    "Verify the system handles boundary input correctly",
                ],
                expected_result="Boundary values are handled according to product rules.",
                data={"constraints": constraints},
                tags=["edge", "boundary", "api"],
            ),
        ]
        return [c.to_dict() for c in cases]
